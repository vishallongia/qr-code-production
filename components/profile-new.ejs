<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>My Profile Page</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        @import url("https://fonts.googleapis.com/css?family=Poppins:400,600");

        :root {
            --blue: rgba(26, 1, 97, 1);
            --grey-6: rgba(30, 29, 33, 1);
            --border-color: #c4c3c3;
        }

        .container-custom-profile {
            width: 552px;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            padding: 20px;
        }

        h1 {
            font-weight: 600;
            color: var(--grey-6);
            font-size: 1.25rem;
            line-height: 1.25;
        }

        .form-container {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            width: 100%;
        }

        .form-fields {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
            width: 100%;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
            width: 100%;
        }

        label {
            font-weight: 400;
            color: var(--grey-6);
            font-size: 1rem;
            line-height: 1.5;
        }

        input {
            width: 100%;
            padding: 0.5rem 1rem;
            border-radius: 0.5rem;
            border: 1px solid var(--border-color);
            font-size: 1rem;
            line-height: 2;
            outline: none;
        }

        .password-field {
            display: flex;
            align-items: center;
            justify-content: space-between;
            width: 100%;
            padding: 0rem 1rem;
            border-radius: 0.5rem;
            border: 1px solid var(--border-color);
        }

        .password-text {
            font-weight: 400;
            color: var(--grey-6);
            font-size: 1rem;
            line-height: 2;
        }

        .container-custom-profile button {
            height: 48px;
            background-color: var(--blue);
            border: none;
            border-radius: 0.5rem;
            color: white;
            font-size: 1rem;
            line-height: 2;
            cursor: pointer;
            transition: opacity 0.2s;
            width: 100%;
        }

        button:hover {
            opacity: 0.9;
        }

        .fa-eye {
            cursor: pointer;
        }

        #editBtn {
            margin-bottom: 16px;
        }
    </style>
</head>

<body>
    <div class="container-custom-profile">
        <h1>My Profile</h1>


        <form class="form-container" id="profileForm" method="POST" onsubmit="return handleUpdateDetailsProfile(event)">
            <div class="form-fields">
                <div class="form-group">
                    <label for="fullName">Full Name</label>
                    <input type="text" id="fullName" name="fullName" value="<%= user.fullName %>" disabled required />
                </div>

                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" name="email" value="<%= user.email %>" disabled required />
                </div>

                <div class="form-group">
                    <label for="password">Password</label>
                    <div class="password-field">
                        <input type="password" id="password" name="password" value="<%= user.userPasswordKey %>"
                            disabled required style="border: none; outline: none; flex-grow: 1;">
                        <i class="fas fa-eye" id="togglePassword"></i>
                    </div>
                </div>
            </div>

            <!-- Buttons -->
            <div>
                <button type="button" id="editBtn">Edit Profile</button>
                <button type="submit" id="updateProfileBtn" style="display: none;">Update</button>
            </div>
        </form>
    </div>


</body>
<script src="https://cdnjs.cloudflare.com/ajax/libs/toastify-js/1.12.0/toastify.min.js"></script>
<script src="/js/toastify-setup.js"></script>
<script src="/js/profile.js"></script>
<script>
    // Check if there's a message passed from the server
    <% if (typeof message !== 'undefined' && message) { %>
        showToast("<%= message %>", "<%= type || 'success' %>");
    <% } %>
</script>

</html>